# === Required for production ===
CORS_ORIGIN=https://app.example.com

# === Optional ===
PORT=3000
MONGODB_URI=mongodb://localhost:27017/fhir
MONGODB_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
LOG_FORMAT=json
BODY_SIZE_LIMIT=5mb
REQUEST_TIMEOUT=30000
MAX_COUNT=1000
MAX_BUNDLE_ENTRIES=1000
MAX_INCLUDE_RESULTS=1000

# SMART on FHIR (disabled by default)
SMART_ENABLED=false
SMART_ISSUER=
SMART_AUDIENCE=
SMART_JWKS_URI=
SMART_SCOPE_CLAIM=scope

# Multi-tenancy (disabled by default)
MULTI_TENANT_ENABLED=false
TENANT_MAX_POOL_SIZE=5

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_MAX_LONG=1000

# FHIR profiles
FHIR_PROFILES_DIR=profiles/r4-core
FHIR_TERMINOLOGY_DIR=profiles/nl-core

# Observability
SLOW_QUERY_THRESHOLD_MS=500
AUDIT_RETENTION_DAYS=365
CACHE_TTL_MS=300000
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318