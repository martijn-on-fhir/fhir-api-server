# === Environment variable overrides ===
# These override values in config/app-config.json for deployment-specific settings.
# See config/app-config.example.json for all available configuration options.

# === Required for production ===
CORS_ORIGIN=https://app.example.com

# === Optional deployment overrides ===
PORT=3000
MONGODB_URI=mongodb://localhost:27017/fhir

# === Secrets (never store in app-config.json) ===
# TERMINOLOGY_USER=
# TERMINOLOGY_PASSWORD=
# BACKUP_AZURE_CONNECTION_STRING=
# BACKUP_S3_BUCKET=
# BACKUP_S3_REGION=

# === Docker-specific (set automatically in docker-compose.yml) ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
